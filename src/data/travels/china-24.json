    {
      "id": "hangzhou-highlights",
      "type": "text",
      "text": "Highlights:\n\u00a0+ West Lake\n\u00a0+ The wonton soup my mom makes\n\u00a0+ Seeing how much the city has developed since I first went 15+ years ago",
      "fontFamily": "var(--font-vt323), monospace",
      "fontSize": "1.2rem",
      "color": "#1f1b17",
      "lineHeight": 1.3,
      "x": 4.1667,
